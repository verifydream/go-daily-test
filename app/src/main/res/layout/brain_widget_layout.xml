<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 Second Brain"
            android:textColor="#E2E3DD"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aktif"
            android:textColor="#9EA398"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Bento Grid Section (Finance and Tasks side by side) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Finance Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_box_finance"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginRight="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💼 KEUANGAN"
                android:textColor="#D7E8CD"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_balance_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo Anda"
                android:textColor="#9EA398"
                android:textSize="9sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/widget_balance_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IDR 0"
                android:textColor="#E2E3DD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Tasks Box -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_box_tasks"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginLeft="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ TUGAS"
                android:textColor="#FCE8D5"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pekerjaan aktif"
                android:textColor="#9EA398"
                android:textSize="9sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/widget_tasks_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 Tersisa"
                android:textColor="#E2E3DD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
